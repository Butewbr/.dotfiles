        "persistent-workspaces": {
            "*": [ 1,2,3,4,5 ]
        }
    },
    "custom/notification": {
        "tooltip-format": "ýĽîŰŽ╝",
        "exec": "~/.config/waybar/scripts/notification_status.sh",
        "on-click": "swaync-client -t -sw",
        "return-type": "json",
        "persistent": true
    },
    "clock": {
        "format": "{:L%p %I:%M %B%eýŁ╝ %A} ",

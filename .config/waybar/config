{
    "layer": "top",
    "icp": true,
    "mode": "hide",
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": ["custom/notification", "tray", "clock"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["group/expand","custom/vpn","network","pulseaudio", "battery"],

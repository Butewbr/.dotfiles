            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ˇ░éä {capacity}%",
        "format-plugged": "ˇ░éä ţČş {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "ˇ░ü╗",
        "ˇ░ü╝",
        "ˇ░üż",
        "ˇ░éÇ",
        "ˇ░éé",
        "ˇ░ü╣"
        ]
    },
    "custom/expand": {
        "format": "´ää",
        "tooltip": false
    },
    "custom/endpoint":{
        "format": "|",
        "tooltip": false
    },
    "group/expand": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 600,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": ["custom/expand", "custom/colorpicker","cpu","memory","temperature","bluetooth", "custom/docker", "custom/endpoint"]
    },
    "custom/colorpicker": {
        "format": "ţłź",
        "return-type": "json",
        "interval": "once",
        "exec": "~/.config/waybar/scripts/colorpicker.sh -j",
        "on-click": "~/.config/waybar/scripts/colorpicker.sh",
        "signal": 1
    },
    "cpu": {
        "format": "ˇ░╗á",
        "tooltip": true
    },
    "memory": {
        "format": "ţ┐ů"
    },
    "temperature": {

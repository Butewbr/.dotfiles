#!/usr/bin/env bash

# Check if external monitor is connected
if xrandr | grep "HDMI-A-1 connected"; then
    # External monitor connected - use it as primary
    xrandr --output HDMI-A-1 --auto --primary
    xrandr --output eDP-1 --auto --left-of HDMI-A-1
else
    # No external monitor - use laptop display
    xrandr --output eDP-1 --auto --primary
    xrandr --output HDMI-A-1 --off 2>/dev/null || true
fi